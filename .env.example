# ============================================================
# YouthGuide NA Frontend - Environment Variables
# Copy this file to .env and fill in your values.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# Never commit .env to version control.
# ============================================================

# Backend API URL
VITE_API_URL=http://localhost:3001/api

# Firebase Web App Configuration
# Get these values from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ============================================================
# Staging / Production changes
# ============================================================
# VITE_API_URL=https://your-production-backend.com/api
# VITE_FIREBASE_AUTH_DOMAIN= (use production project domain)
# VITE_FIREBASE_PROJECT_ID= (use production project ID)
